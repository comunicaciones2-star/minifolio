# Base path for production static export (optional)
NEXT_PUBLIC_BASE_PATH=/minifolio

# PIN de acceso al dashboard — definir como GitHub Secret (Settings → Secrets → Actions)
# NO commitear el valor real aquí ni en .env.production
NEXT_PUBLIC_DASHBOARD_PIN=

# Analytics con Umami (opcional, sin cookies)
# Crear cuenta en https://umami.is → añadir sitio → copiar el Website ID
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Formulario de contacto con Web3Forms (gratis, 250 envíos/mes)
# Crear cuenta en https://web3forms.com → copiar el Access Key
NEXT_PUBLIC_WEB3FORMS_KEY=8654
